# --- Core Settings ---
PORT=5000
NODE_ENV=development

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/finnovax

# --- JWT Secrets ---
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
FRONTEND_URL=http://localhost:5173

# --- External Services (LocalStack or Cloud) ---
# S3 / Cloudinary
AWS_BUCKET_NAME=finnovax-bucket
AWS_ENDPOINT_URL=http://localhost:4566
PUBLIC_S3_URL=http://localhost:4566
AWS_REGION=ap-south-1
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Email Settings (Nodemailer via Gmail/SMTP)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# SNS / Twilio (SMS)
# TWILIO_ACCOUNT_SID=AC1234567890
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

ML_SERVICE_URL=https://YOUR_PYTHON_RENDER_URL.onrender.com
