# --- Core Settings ---
PORT=5000
NODE_ENV=development

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/kfintech-nexus

# --- JWT Secrets ---
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# --- External Services (LocalStack or Cloud) ---
# S3 / Cloudinary
AWS_BUCKET_NAME=kfintech-bucket
AWS_ENDPOINT_URL=http://localhost:4566
PUBLIC_S3_URL=http://localhost:4566
AWS_REGION=ap-south-1
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# SES / Resend (Email)
SES_FROM_EMAIL=test@example.com
# RESEND_API_KEY=re_123456789
# RESEND_FROM_EMAIL=FinnovaX <onboarding@resend.dev>

# SNS / Twilio (SMS)
# TWILIO_ACCOUNT_SID=AC1234567890
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

ML_SERVICE_URL=https://YOUR_PYTHON_RENDER_URL.onrender.com
